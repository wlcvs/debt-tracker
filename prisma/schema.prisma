generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  people       Person[]
  creditCards  CreditCard[]
  statements   Statement[]
  LLMFeedbacks LLMFeedback[]
}

model Person {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  debts    Debt[]
  payments Payment[]
}

model CreditCard {
  id        String   @id @default(cuid())
  userId    String
  label     String
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  debts Debt[]
}

model Debt {
  id                 String         @id @default(cuid())
  personId           String
  creditCardId       String?
  method             PaymentMethod?
  amount             Decimal        @db.Decimal(10, 2)
  title              String
  description        String         @default("")
  paid               Boolean        @default(false)
  date               DateTime
  installmentGroupId String?
  installmentIndex   Int?
  installmentTotal   Int?
  createdAt          DateTime       @default(now())

  person     Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id], onDelete: SetNull)

  @@index([installmentGroupId])
}

enum PaymentMethod {
  PIX
  CASH
}

model Payment {
  id          String        @id @default(cuid())
  personId    String
  amount      Decimal       @db.Decimal(10, 2)
  description String        @default("")
  date        DateTime
  method      PaymentMethod @default(CASH)
  createdAt   DateTime      @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model Statement {
  id               String   @id @default(cuid())
  userId           String
  bank             String
  filename         String
  pdfData          Bytes
  transactionCount Int      @default(0)
  algoResults      Json     @default("[]")
  LLMResults       Json     @default("[]")
  extractedText    String   @default("")
  uploadedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, uploadedAt])
}

model LLMFeedback {
  id          String   @id @default(cuid())
  userId      String
  bank        String
  date        DateTime
  description String
  amount      Decimal  @db.Decimal(10, 2)
  context     String   @default("")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, bank, createdAt])
}
